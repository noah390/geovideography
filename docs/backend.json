{
  "entities": {
    "Country": {
      "title": "Country",
      "type": "object",
      "description": "Sovereign nation data.",
      "properties": {
        "name": { "type": "string" },
        "flagUrl": { "type": "string", "format": "uri" },
        "history": { "type": "string" },
        "population": { "type": "number" }
      }
    },
    "Street": {
      "title": "Street Telemetry",
      "type": "object",
      "description": "Granular infrastructure intelligence.",
      "properties": {
        "name": { "type": "string" },
        "treeCount": { "type": "number" },
        "roadConditionScore": { "type": "number" },
        "healthIndex": { "type": "number" },
        "videoUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/countries/{countryId}",
        "definition": {
          "entityName": "Country",
          "description": "Public country registry."
        }
      }
    ]
  },
  "dataConnect": {
    "description": "Primary relational engine for deep-grid street telemetry and vector search.",
    "service": "geovideography-service",
    "location": "us-central1"
  }
}
