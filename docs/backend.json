{
  "entities": {
    "Country": {
      "title": "Sovereign Nation",
      "type": "object",
      "description": "Top-level national dataset.",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "flagUrl": { "type": "string", "format": "uri" },
        "historySummary": { "type": "string" },
        "populationCount": { "type": "integer" }
      }
    },
    "LGA": {
      "title": "Local Government Area",
      "type": "object",
      "description": "Administrative division within a country.",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "countryId": { "type": "string", "format": "uuid" }
      }
    },
    "Town": {
      "title": "Town / Estate",
      "type": "object",
      "description": "Urban or residential node.",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "lgaId": { "type": "string", "format": "uuid" }
      }
    },
    "Street": {
      "title": "Street Telemetry",
      "type": "object",
      "description": "Granular infrastructure intelligence node.",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "townId": { "type": "string", "format": "uuid" },
        "videoUrl": { "type": "string", "format": "uri" },
        "treeCount": { "type": "integer" },
        "roadCondition": { "type": "string" },
        "healthScore": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "dataConnect": {
    "description": "Primary relational engine for deep-grid street telemetry and vector search.",
    "service": "geovideography-service",
    "location": "us-central1"
  },
  "firestore": {
    "structure": [
      {
        "path": "/countries/{countryId}",
        "definition": {
          "entityName": "Country",
          "description": "Public country registry mirrored from Data Connect for fast edge reads."
        }
      }
    ]
  }
}
